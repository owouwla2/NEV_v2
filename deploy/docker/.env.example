# NEV-v2 docker-compose 环境变量模板
# 用法：cp .env.example .env 后按需修改；不传 .env 时使用 compose 内置默认值。
# .env 含密码，已被 .gitignore 忽略，不会进库。

# MySQL ----------------------------------------------------------
MYSQL_PORT=13306
MYSQL_DATABASE=nev_v2
MYSQL_ROOT_PASSWORD=nev_v2_root_2026

# Redis ----------------------------------------------------------
# 默认 6379 与老仓 Redis 端口相同；如老仓 Redis 已在跑，把端口改为 6479（或先关老仓）
# 业务侧通过 application-*.yml 的 spring.data.redis.database=1 与老仓隔离
REDIS_PORT=6379
REDIS_PASSWORD=nev_v2_redis_2026
