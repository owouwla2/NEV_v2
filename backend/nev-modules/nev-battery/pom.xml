        </dependency>
        <dependency>
            <groupId>com.nev</groupId>
            <artifactId>ruoyi-common-mybatis</artifactId>
        </dependency>
        <dependency>
            <groupId>com.nev</groupId>
            <artifactId>ruoyi-common-json</artifactId>
        </dependency>
        <dependency>
            <groupId>com.nev</groupId>
            <artifactId>ruoyi-common-satoken</artifactId>
        </dependency>
        <dependency>
            <groupId>com.nev</groupId>
            <artifactId>ruoyi-common-log</artifactId>
        </dependency>
    </dependencies>

</project>
