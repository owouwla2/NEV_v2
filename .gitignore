# =============================================================================
# Java / Maven
# =============================================================================
target/
*.class
*.jar
!gradle-wrapper.jar
!.mvn/wrapper/maven-wrapper.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*
.mvn/
mvnw
mvnw.cmd

# =============================================================================
# Spring Boot
# =============================================================================
*.log
*.log.*
logs/
spring-boot-*.log
# NEV-v2: 默认忽略所有 application-prod.yml，避免 RuoYi 上游模板的硬编码密码进库
**/application-prod.yml
**/application-prod.properties
# 例外：ruoyi-admin 的 prod.yml 已改造为 ${ENV:default} 占位符模板，可入库
!backend/ruoyi-admin/src/main/resources/application-prod.yml
application-secret.yml
application-secret.properties

# =============================================================================
# Node.js / npm / pnpm / yarn
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock

# =============================================================================
# Frontend build outputs
# =============================================================================
dist/
dist-ssr/
build/
.vite/
.cache/
.parcel-cache/
.turbo/
.next/

# Contracts build artifacts MUST be committed (D9 solc output, D10 web3j input,
# D11 deployment source). Whitelist them out of the generic build/ rule above.
!contracts/build/
!contracts/build/**

# Private keys / wallet files MUST NEVER be committed
contracts/pk/
contracts/keys/
*.p12
*.pem
!contracts/build/**/*.pem
.nuxt/
*.local

# =============================================================================
# Solidity / Hardhat / Truffle
# =============================================================================
artifacts/
cache/
typechain/
typechain-types/
coverage.json
coverage/
.openzeppelin/
.deployments/

# =============================================================================
# Database
# =============================================================================
*.db
*.sqlite
*.sqlite3
data/mysql/
data/redis/
data/mongo/

# =============================================================================
# Docker volumes
# =============================================================================
volumes/

# =============================================================================
# IDE - JetBrains (IntelliJ IDEA / WebStorm)
# =============================================================================
.idea/
*.iml
*.iws
*.ipr
out/

# =============================================================================
# IDE - VS Code
# =============================================================================
.vscode/
*.code-workspace

# =============================================================================
# IDE - Eclipse
# =============================================================================
.classpath
.project
.settings/
.metadata/

# =============================================================================
# OS - Windows
# =============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# OS - macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*

# =============================================================================
# OS - Linux
# =============================================================================
*~
.fuse_hidden*
.directory
.Trash-*

# =============================================================================
# Sensitive files
# =============================================================================
*.pem
*.key
*.cer
*.crt
.env
.env.local
.env.*.local
secrets/

# =============================================================================
# Project-specific
# =============================================================================
# 上传文件目录（运行时生成）
uploads/
upload/
file-storage/

# vibe 治理证据（运行时生成）
outputs/runtime/vibe-sessions/

# 备份文件
*.bak
*.backup
backups/

# 临时文件
tmp/
temp/
*.tmp

# 测试覆盖率
.coverage
htmlcov/
.pytest_cache/
.tox/

# Allure 报告
allure-results/
allure-report/

# JaCoCo
jacoco.exec

# spec-workflow MCP 工具产物（不入库）
.spec-workflow/
